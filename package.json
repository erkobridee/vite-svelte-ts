{
  "name": "vite-svelte-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "unset:git-hooks-path": "git config --unset core.hooksPath",
    "simple-git-hooks": "npx simple-git-hooks",
    "postinstall": "is-ci || npm run simple-git-hooks",
    "prettier": "prettier --write .",
    "eslint": "eslint --fix \"src/**/*.{js,ts,svelte}\"",
    "lint": "run-s prettier eslint",
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "ci": "cross-env NODE_ENV=production run-s build"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "4.3.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "24.12.4",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "cross-env": "10.1.0",
    "eslint": "10.4.0",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.6.0",
    "is-ci": "4.1.0",
    "lint-staged": "17.0.5",
    "npm-run-all2": "9.0.0",
    "picomatch": "4.0.4",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "simple-git-hooks": "2.13.1",
    "svelte-check": "4.4.8",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vite-tsconfig-paths": "6.1.1"
  },
  "dependencies": {
    "svelte": "5.55.8",
    "tailwindcss": "4.3.0"
  },
  "lint-staged": {
    "**/*.{js,ts,md,mdx,svelte}": "prettier --write",
    "src/**/*.{js,ts,svelte}": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}